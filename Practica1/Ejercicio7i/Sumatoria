package practica1ejercicio7;
import java.util.*;

public class Sumatoria {
	public static int sumarLinkedList(List<Integer> lista) {
		int indice=0;
		int sumaTotal = sumarLinkedListRecursivo(lista,indice);
		return sumaTotal;
	}
	
	public static int sumarLinkedListRecursivo(List<Integer> lista, int indice) {
		if (indice == lista.size()) {
			return 0;
		}
		else {
			return lista.get(indice) + sumarLinkedListRecursivo(lista, indice+1);
		}
	}
}
